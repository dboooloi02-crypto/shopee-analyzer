{
  "manifest_version": 3,
  "name": "Shopee Scout",
  "version": "2.2.4",
  "description": "从 Shopee 搜索结果页一键提取商品数据",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "*://shopee.tw/*",
    "*://shopee.com.my/*",
    "*://shopee.co.th/*",
    "*://shopee.vn/*",
    "*://shopee.co.id/*",
    "*://shopee.ph/*",
    "*://shopee.sg/*",
    "*://*.xiapibuy.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Shopee Scout",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://shopee.tw/search*",
        "*://shopee.com.my/search*",
        "*://shopee.co.th/search*",
        "*://shopee.vn/search*",
        "*://shopee.co.id/search*",
        "*://shopee.ph/search*",
        "*://shopee.sg/search*",
        "*://*.xiapibuy.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}